[user]
    useConfigOnly = true
[core]
    editor = nano
    excludesfile = ~/.gitignore_global
    autocrlf = input
    # This replaces Git's default per-repo .git/hooks lookup.
    # Our global hooks restore only a trimmed whitelist of hook names and forward those to .git/hooks/<name>.
    # post-commit is special: it runs the rounded timestamp logic first, then forwards the repo-local post-commit.
    hooksPath = ~/.local/share/git/hooks
[init]
    defaultBranch = main
[branch]
    sort = -committerdate
[tag]
    sort = version:refname
[diff]
    algorithm = histogram
    colorMoved = plain
    mnemonicPrefix = true
    renames = true
[fetch]
    prune = true
    pruneTags = false
[pull]
    ff = only
[push]
    autoSetupRemote = true
    default = current
[rebase]
    autoStash = true
    updateRefs = false

[help]
    autocorrect = prompt

[round-commit-date]
    enabled = true
    stepSeconds = 60

[alias]
    co = checkout
    ci = commit
    ci-plain = -c round-commit-date.enabled=false commit
    ci0 = -c round-commit-date.stepSeconds=10 commit
    ci00 = -c round-commit-date.stepSeconds=60 commit
    st = status
    stu = status -uno
    br = branch
    rso = remote show origin
    hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
    type = cat-file -t
    dump = cat-file -p
    ######################
    fp = fetch --prune
    pp = pull --prune
    ######################
    ssave = stash save
    slist = stash list
    speek = stash apply stash@{0}
    ######################
    lol = log --graph --decorate --pretty=oneline --abbrev-commit
    lola = log --graph --decorate --pretty=oneline --abbrev-commit --all
    fuckit = reset --hard HEAD
    ######################
    # Will clean up local branches, removing those that don't have a remote anymore (like merged after a PR).
    # Won't remove branches that are ONLY in local.
    prune-branches = "!git fetch -p && for branch in `git branch -vv | grep ': gone]' | awk '{print $1}'`; do git branch -D $branch; done"
    ######################

[filter "lfs"]
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f

[diff "lockb"]
    textconv = bun
    binary = true

{{-  if .personal }}

[github]
    user = zbiljic

[url "git@github.com:zbiljic/"]
    insteadOf = https://github.com/zbiljic/
{{- end }}

{{ $path := printf "%s_extra" .chezmoi.targetFile }}
{{- if stat $path }}
{{ include $path }}
{{- end }}
