{{ $hostname := .hostname }}
{{- $username := .chezmoi.username }}
{{- if or (hasPrefix "nemanja" (lower $hostname)) (hasPrefix "nemanja" (lower $username)) -}}
#!/bin/sh

if ! command -v fresh >/dev/null 2>&1; then
    echo "nvim compatibility wrapper: fresh is not available" >&2
    exit 127
fi

if [ "$#" -ge 2 ]; then
    case "$1" in
        +[0-9]*)
            line=${1#+}
            shift
            file=$1
            shift
            exec fresh "${file}:${line}" "$@"
            ;;
    esac
fi

exec fresh "$@"
{{- end }}
